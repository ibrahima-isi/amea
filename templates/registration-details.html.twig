{% extends 'layouts/base.html.twig' %}

{% block title %}Détails de l'inscription - AEESGS{% endblock %}

{% block stylesheets %}
    <style>
      .detail-row {
        border-bottom: 1px solid #eee;
        padding: 12px 0;
      }
      .detail-row:last-child {
        border-bottom: none;
      }
      .detail-label {
        font-weight: 600;
        color: var(--brand-dark);
        width: 40%;
        display: inline-block;
      }
      .detail-value {
        color: #333;
        width: 55%;
        display: inline-block;
      }
      .section-title {
        color: var(--brand-primary);
        border-bottom: 2px solid var(--brand-accent);
        padding-bottom: 5px;
        margin-bottom: 20px;
        margin-top: 20px;
      }
    </style>
{% endblock %}

{% block body %}
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-10">
          <div class="alert alert-success shadow-sm mb-4 border-left-success">
            <h4 class="alert-heading">
              <i class="fas fa-check-circle"></i> Inscription réussie !
            </h4>
            <p>
              Votre inscription a été enregistrée avec succès. Veuillez vérifier
              les informations ci-dessous. Vous pouvez les modifier si
              nécessaire avant de valider votre dossier.
            </p>
          </div>

          <div class="card shadow-lg border-0">
            <div class="card-header bg-primary text-white py-3">
              <h4 class="m-0">
                <i class="fas fa-id-card"></i> Récapitulatif de votre inscription
              </h4>
            </div>
            <div class="card-body p-4">
              <div class="row">
                <div class="col-md-4 text-center mb-4">
                  <div class="mb-3">
                    <img
                      src="{{ student.identityDocument ? asset(student.identityDocument) : asset('assets/img/placeholder.png') }}"
                      alt="Photo d'identité"
                      class="img-thumbnail rounded-circle shadow-sm"
                      style="width: 150px; height: 150px; object-fit: cover"
                    />
                  </div>
                  <h3 class="text-primary">{{ student.firstName }} {{ student.lastName }}</h3>
                  <p class="text-muted mb-1">{{ student.status }}</p>
                  <span class="badge bg-warning text-dark student-school-badge">{{ student.institution }}</span>
                </div>

                <div class="col-md-8">
                  <h5 class="section-title">
                    <i class="fas fa-user"></i> Informations Personnelles
                  </h5>
                  <div class="detail-row">
                    <span class="detail-label">Date de naissance:</span>
                    <span class="detail-value">{{ student.birthDate }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Sexe:</span>
                    <span class="detail-value">{{ student.gender }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Nationalités:</span>
                    <span class="detail-value">{{ student.nationalities|join(', ') }}</span>
                  </div>

                  <h5 class="section-title">
                    <i class="fas fa-address-book"></i> Coordonnées & Résidence
                  </h5>
                  <div class="detail-row">
                    <span class="detail-label">Email:</span>
                    <span class="detail-value">{{ student.email }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Téléphone:</span>
                    <span class="detail-value">{{ student.phone }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Lieu de résidence:</span>
                    <span class="detail-value">{{ student.residence }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Type de logement:</span>
                    <span class="detail-value">{{ student.housingType }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Année d'arrivée:</span>
                    <span class="detail-value">{{ student.arrivalYear }}</span>
                  </div>

                  <h5 class="section-title">
                    <i class="fas fa-graduation-cap"></i> Informations Académiques
                  </h5>
                  <div class="detail-row">
                    <span class="detail-label">Domaine d'études:</span>
                    <span class="detail-value">{{ student.studyField }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Niveau d'études:</span>
                    <span class="detail-value">{{ student.studyLevel }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Projets futurs:</span>
                    <span class="detail-value">{{ student.postTrainingProject|nl2br }}</span>
                  </div>

                  <h5 class="section-title">
                    <i class="fas fa-file-alt"></i> Documents
                  </h5>
                  {% if student.cvPath %}
                      <div class="detail-row">
                        <span class="detail-label">CV:</span>
                        <span class="detail-value">
                            <a href="{{ asset(student.cvPath) }}" download class="btn btn-sm btn-info me-2"><i class="fas fa-download"></i> Télécharger</a>
                            <button type="button" class="btn btn-sm btn-secondary" data-bs-toggle="modal" data-bs-target="#cvModal"><i class="fas fa-eye"></i> Voir</button>
                        </span>
                      </div>
                  {% else %}
                      <p class="text-muted">Aucun CV fourni.</p>
                  {% endif %}
                </div>
              </div>
            </div>
            <div class="card-footer bg-light p-3 d-flex justify-content-between">
              <a href="register.php?action=edit" class="btn btn-warning btn-lg">
                <i class="fas fa-edit"></i> Modifier mes informations
              </a>
              <form method="POST" action="registration-details.php" class="d-inline">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />
                <button type="submit" class="btn btn-success btn-lg">
                  <i class="fas fa-check"></i> Confirmer et Envoyer pour révision
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    {% if student.cvPath %}
        <div class="modal fade" id="cvModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-centered">
                <div class="modal-content" style="height: 90vh;">
                    <div class="modal-header">
                        <h5 class="modal-title">Mon CV</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center p-0">
                        {% if student.cvPath|lower|slice(-3) == 'pdf' %}
                            <iframe src="{{ asset(student.cvPath) }}" width="100%" height="100%" style="border:none;"></iframe>
                        {% else %}
                            <img src="{{ asset(student.cvPath) }}" class="img-fluid" style="max-height: 100%; max-width: 100%;">
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
