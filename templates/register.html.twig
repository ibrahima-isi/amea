{% extends 'layouts/base.html.twig' %}

{% block title %}AEESGS - Enregistrement{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/css/tagify.css') }}" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
{% endblock %}

{% block body %}
    <main class="py-5">
      <div class="container">
        <div class="row">
          <div class="col-lg-10 mx-auto">
            <div class="card shadow">
              <div class="card-header">
                <h2 class="h4 mb-0">
                  Formulaire d'enregistrement des élèves, étudiants et
                  stagiaires guinéens au Sénégal
                </h2>
              </div>
              <div class="card-body">
                {% if is_correction %}
                    <div class="alert alert-warning mb-4">
                        <h4 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Correction requise</h4>
                        <p class="mb-0">{{ kyc_notes }}</p>
                    </div>
                {% endif %}

                <p class="text-muted mb-4">
                  Veuillez remplir ce formulaire pour vous enregistrer dans la
                  base de données des élèves, étudiants et stagiaires guinéens
                  au Sénégal.
                </p>

                <form
                  action="{{ is_correction ? 'kyc-correction.php?token=' ~ token : 'register.php' }}"
                  method="POST"
                  id="registrationForm"
                  enctype="multipart/form-data"
                  novalidate
                >
                  <input
                    type="hidden"
                    name="csrf_token"
                    value="{{ csrf_token }}"
                  />
                  <!-- Informations personnelles -->
                  <h3 class="registration-section-heading">
                    <span class="registration-section-title">Informations personnelles</span>
                  </h3>
                  <div class="row g-3 mb-4">
                    <div class="col-md-6">
                      <label for="last_name" class="form-label">Nom <span class="text-danger">*</span></label>
                      <input
                        type="text"
                        class="form-control {{ errors.last_name ? 'is-invalid' : '' }}"
                        id="last_name"
                        name="last_name"
                        value="{{ formData.last_name }}"
                        required
                      />
                      <div class="text-danger">{{ errors.last_name }}</div>
                    </div>
                    <div class="col-md-6">
                      <label for="first_name" class="form-label">Prénom <span class="text-danger">*</span></label>
                      <input
                        type="text"
                        class="form-control {{ errors.first_name ? 'is-invalid' : '' }}"
                        id="first_name"
                        name="first_name"
                        value="{{ formData.first_name }}"
                        required
                      />
                      <div class="text-danger">{{ errors.first_name }}</div>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Sexe <span class="text-danger">*</span></label>
                      <div class="form-check">
                        <input
                          class="form-check-input {{ errors.gender ? 'is-invalid' : '' }}"
                          type="radio"
                          name="gender"
                          id="genderMasculin"
                          value="Masculin"
                          {{ formData.gender == 'Masculin' ? 'checked' : '' }}
                          required
                        />
                        <label class="form-check-label" for="genderMasculin">Masculin</label>
                      </div>
                      <div class="form-check">
                        <input
                          class="form-check-input {{ errors.gender ? 'is-invalid' : '' }}"
                          type="radio"
                          name="gender"
                          id="genderFeminin"
                          value="Féminin"
                          {{ formData.gender == 'Féminin' ? 'checked' : '' }}
                          required
                        />
                        <label class="form-check-label" for="genderFeminin">Féminin</label>
                      </div>
                      <div class="text-danger">{{ errors.gender }}</div>
                    </div>
                    <div class="col-md-6">
                      <label for="status" class="form-label">Statut <span class="text-danger">*</span></label>
                      <select class="form-select {{ errors.status ? 'is-invalid' : '' }}" id="status" name="status" required>
                        <option value="" {{ not formData.status ? 'selected' : '' }}>Sélectionnez</option>
                        {% for code, label in {'ELEVE': 'Élève', 'ETUDIANT': 'Étudiant', 'STAGIAIRE': 'Stagiaire'} %}
                          <option value="{{ code }}" {{ formData.status == code ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                      </select>
                      <div class="text-danger">{{ errors.status }}</div>
                    </div>

                    <div class="col-md-12 mb-3">
                      <label for="nationalities" class="form-label">Nationalité <span class="text-danger">*</span></label>
                      <input
                        name="nationalities"
                        id="nationalities"
                        class="form-control {{ errors.nationalities ? 'is-invalid' : '' }}"
                        placeholder="Nationalité (max 5)"
                        value="{{ formData.nationalities }}"
                        required
                      />
                      <div class="form-text">Tapez et sélectionnez parmi la liste.</div>
                      <div class="text-danger">{{ errors.nationalities }}</div>
                    </div>

                    <div class="col-md-6">
                      <label for="birth_date" class="form-label">Date de naissance</label>
                      <input
                        type="text"
                        class="form-control {{ errors.birth_date ? 'is-invalid' : '' }}"
                        id="birth_date"
                        name="birth_date"
                        value="{{ formData.birth_date }}"
                        data-max-date="{{ "now"|date_modify("-15 years")|date("Y-12-31") }}"
                        placeholder="JJ/MM/AAAA"
                      />
                      <div class="text-danger">{{ errors.birth_date }}</div>
                    </div>
                    <div class="col-md-6">
                      <label for="phone" class="form-label">Téléphone <span class="text-danger">*</span></label>
                      <input
                        type="tel"
                        class="form-control {{ errors.phone ? 'is-invalid' : '' }}"
                        id="phone"
                        name="phone"
                        value="{{ formData.phone }}"
                        placeholder="Saisissez votre numero sans l'indicatif du pays (9 chiffres)"
                        required
                      />
                      <div class="text-danger">{{ errors.phone }}</div>
                    </div>
                    <div class="col-md-6">
                      <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
                      <input
                        type="email"
                        class="form-control {{ errors.email ? 'is-invalid' : '' }}"
                        id="email"
                        name="email"
                        value="{{ formData.email }}"
                        placeholder="nom.prenom@exemple.com"
                        required
                      />
                      <div class="text-danger">{{ errors.email }}</div>
                    </div>

                    <div class="col-md-6">
                      <label for="photo" class="form-label">Pièce d'identité</label>
                      <input
                        type="file"
                        class="form-control {{ errors.identity_document ? 'is-invalid' : '' }}"
                        id="photo"
                        name="photo"
                        accept="image/*,application/pdf"
                      />
                      <div class="text-danger">{{ errors.identity_document }}</div>
                    </div>
                  </div>

                  <!-- Informations de contact et résidence -->
                  <h3 class="mb-0">
                    <button
                      type="button"
                      class="registration-section-heading registration-section-toggle"
                      aria-expanded="false"
                      aria-controls="contactResidenceSection"
                    >
                      <span class="registration-section-title"
                        >Contact et résidence
                        <span class="registration-section-badge">(optionnel)</span></span
                      >
                      <span class="registration-toggle-meta"
                        ><span class="registration-toggle-label">Déplier</span><i class="fas fa-chevron-down" aria-hidden="true"></i></span>
                    </button>
                  </h3>
                  <div id="contactResidenceSection" class="registration-section-panel" data-registration-section-panel>
                    <div class="row g-3">
                      <div class="col-md-6">
                        <label for="residence" class="form-label">Lieu de résidence au Sénégal</label>
                        <select class="form-select {{ errors.residence ? 'is-invalid' : '' }}" id="residence" name="residence">
                          <option value="">Sélectionnez un lieu</option>
                          {% for region, cities in locations %}
                            <optgroup label="{{ region }}">
                              {% for city in cities %}
                                <option value="{{ city }}" {{ formData.residence == city ? 'selected' : '' }}>{{ city }}</option>
                              {% endfor %}
                            </optgroup>
                          {% endfor %}
                          <option value="Autre" {{ formData.residence == 'Autre' ? 'selected' : '' }}>Autre</option>
                        </select>
                        <div class="text-danger">{{ errors.residence }}</div>
                      </div>
                      <div class="col-md-6" id="other_residence_wrapper" style="{{ formData.residence == 'Autre' ? '' : 'display: none' }}">
                        <label for="other_residence" class="form-label">Précisez le lieu de résidence</label>
                        <input type="text" class="form-control" id="other_residence" name="other_residence" value="{{ formData.other_residence }}" />
                      </div>
                      <div class="col-md-6">
                        <label for="arrival_year" class="form-label">Année d'arrivée au Sénégal</label>
                        <select class="form-select" id="arrival_year" name="arrival_year">
                          <option value="">Sélectionnez</option>
                          {% for year in "now"|date("Y")..1990 %}
                            <option value="{{ year }}" {{ formData.arrival_year == year ? 'selected' : '' }}>{{ year }}</option>
                          {% endfor %}
                        </select>
                      </div>
                      <div class="col-md-6">
                        <label for="housing_type" class="form-label">Type de logement</label>
                        <select class="form-select {{ errors.housing_type ? 'is-invalid' : '' }}" id="housing_type" name="housing_type">
                          <option value="" {{ not formData.housing_type ? 'selected' : '' }}>Sélectionnez</option>
                          {% for type in ['Colocation', 'Famille', 'Hébergement temporaire', 'Location', 'Résidence universitaire', 'Autre'] %}
                            <option value="{{ type }}" {{ formData.housing_type == type ? 'selected' : '' }}>{{ type }}</option>
                          {% endfor %}
                        </select>
                        <div class="text-danger">{{ errors.housing_type }}</div>
                      </div>
                      <div class="col-md-6">
                        <label for="housing_details" class="form-label">Précisions sur le logement</label>
                        <input type="text" class="form-control" id="housing_details" name="housing_details" value="{{ formData.housing_details }}" />
                      </div>
                    </div>
                  </div>

                  <!-- Informations académiques -->
                  <h3 class="mb-0">
                    <button
                      type="button"
                      class="registration-section-heading registration-section-toggle"
                      aria-expanded="false"
                      aria-controls="academicSection"
                    >
                      <span class="registration-section-title"
                        >Informations académiques
                        <span class="registration-section-badge">(optionnel)</span></span
                      >
                      <span class="registration-toggle-meta"
                        ><span class="registration-toggle-label">Déplier</span><i class="fas fa-chevron-down" aria-hidden="true"></i></span>
                    </button>
                  </h3>
                  <div id="academicSection" class="registration-section-panel" data-registration-section-panel>
                    <div class="row g-3">
                      <div class="col-md-6">
                        <label for="institution" class="form-label">Établissement</label>
                        <select class="form-select {{ errors.institution ? 'is-invalid' : '' }}" id="institution" name="institution">
                          <option value="">Sélectionnez votre établissement</option>
                          {% for school in schools %}
                            <option value="{{ school }}" {{ formData.institution == school ? 'selected' : '' }}>{{ school }}</option>
                          {% endfor %}
                          <option value="Autre" {{ formData.institution == 'Autre' ? 'selected' : '' }}>Autre</option>
                        </select>
                        <div class="text-danger">{{ errors.institution }}</div>
                      </div>
                      <div class="col-md-6" id="other_institution_wrapper" style="{{ formData.institution == 'Autre' ? '' : 'display: none' }}">
                        <label for="other_institution" class="form-label">Précisez l'établissement</label>
                        <input type="text" class="form-control" id="other_institution" name="other_institution" value="{{ formData.other_institution }}" />
                      </div>
                      <div class="col-md-6">
                        <label for="study_field" class="form-label">Domaine d'études</label>
                        <select class="form-select {{ errors.study_field ? 'is-invalid' : '' }}" id="study_field" name="study_field">
                          <option value="">Sélectionnez votre domaine d'études</option>
                          {% for d in domaines %}
                            <option value="{{ d }}" {{ formData.study_field == d ? 'selected' : '' }}>{{ d }}</option>
                          {% endfor %}
                          <option value="Autre" {{ formData.study_field == 'Autre' ? 'selected' : '' }}>Autre</option>
                        </select>
                        <div class="text-danger">{{ errors.study_field }}</div>
                      </div>
                      <div class="col-md-6" id="other_study_field_wrapper" style="{{ formData.study_field == 'Autre' ? '' : 'display: none' }}">
                        <label for="other_study_field" class="form-label">Précisez le domaine d'études</label>
                        <input type="text" class="form-control" id="other_study_field" name="other_study_field" value="{{ formData.other_study_field }}" />
                      </div>
                      <div class="col-md-6">
                        <label for="study_level" class="form-label">Niveau d'études</label>
                        <select class="form-select {{ errors.study_level ? 'is-invalid' : '' }}" id="study_level" name="study_level">
                          <option value="">Sélectionnez votre niveau d'études</option>
                          {% for n in niveaux %}
                            <option value="{{ n }}" {{ formData.study_level == n ? 'selected' : '' }}>{{ n }}</option>
                          {% endfor %}
                          <option value="Autre" {{ formData.study_level == 'Autre' ? 'selected' : '' }}>Autre</option>
                        </select>
                        <div class="text-danger">{{ errors.study_level }}</div>
                      </div>
                      <div class="col-md-6" id="other_study_level_wrapper" style="{{ formData.study_level == 'Autre' ? '' : 'display: none' }}">
                        <label for="other_study_level" class="form-label">Précisez le niveau d'études</label>
                        <input type="text" class="form-control" id="other_study_level" name="other_study_level" value="{{ formData.other_study_level }}" />
                      </div>
                    </div>
                  </div>

                  <!-- Projets futurs -->
                  <h3 class="mb-0">
                    <button
                      type="button"
                      class="registration-section-heading registration-section-toggle"
                      aria-expanded="false"
                      aria-controls="futureProjectSection"
                    >
                      <span class="registration-section-title"
                        >Projets futurs
                        <span class="registration-section-badge">(optionnel)</span></span
                      >
                      <span class="registration-toggle-meta"
                        ><span class="registration-toggle-label">Déplier</span><i class="fas fa-chevron-down" aria-hidden="true"></i></span>
                    </button>
                  </h3>
                  <div id="futureProjectSection" class="registration-section-panel" data-registration-section-panel>
                    <div class="mb-4">
                      <label for="post_training_project" class="form-label">Projet après formation</label>
                      <textarea class="form-control" id="post_training_project" name="post_training_project" rows="3" placeholder="Décrivez vos projets futurs...">{{ formData.post_training_project }}</textarea>
                    </div>
                      <div class="mb-4">
                        <label for="cv_file" class="form-label">Télécharger CV (PDF, PNG - max 5MB)</label>
                        <input type="file" class="form-control {{ errors.cv ? 'is-invalid' : '' }}" id="cv_file" name="cv_file" accept="application/pdf,image/png">
                        <div class="text-danger">{{ errors.cv }}</div>
                      </div>
                  </div>

                  <!-- Mentions légales et consentement -->
                  <h3 class="registration-section-heading">
                    <span class="registration-section-title">Mentions légales et consentement <span class="registration-section-badge text-danger">(obligatoire)</span></span>
                  </h3>
                  <div id="legalConsentSection" class="registration-section-panel is-open" style="height:auto; opacity:1; transform:none;" aria-hidden="false">
                    <div class="mb-4">
                      <div class="form-check {{ errors.consent_privacy ? 'is-invalid' : '' }}">
                        <input class="form-check-input" type="checkbox" name="consent_privacy" id="consentPrivacy" value="1" {{ formData.consent_privacy ? 'checked' : '' }} required />
                        <label class="form-check-label" for="consentPrivacy">
                          J'accepte les <a href="legal-notice.php" target="_blank" class="text-decoration-underline">Conditions Générales d'Utilisation</a>
                          et la <a href="legal-notice.php#privacy" target="_blank" class="text-decoration-underline">Politique de Confidentialité</a>.
                          <div class="form-text text-muted mt-1">
                            En cochant cette case, vous acceptez le traitement de vos données conformément à la loi n° 2008-12.
                          </div>
                        </label>
                        <div class="text-danger">{{ errors.consent_privacy }}</div>
                      </div>
                    </div>
                  </div>

                  <!-- Boutons de soumission -->
                  <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a href="/" class="btn btn-secondary"><i class="fas fa-times"></i> Annuler</a>
                    <button type="reset" class="btn btn-outline-secondary"><i class="fas fa-undo"></i> Réinitialiser</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Enregistrer</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
{% endblock %}

{% block javascripts %}
    <script src="https://npmcdn.com/flatpickr/dist/flatpickr.min.js"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/fr.js"></script>
    <script src="{{ asset('assets/js/tagify.min.js') }}"></script>
    <script src="{{ asset('assets/js/main.js') }}"></script>
    <script src="{{ asset('assets/js/register.js') }}"></script>
{% endblock %}
