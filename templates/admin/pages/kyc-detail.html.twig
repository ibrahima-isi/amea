{% extends 'layouts/base.html.twig' %}

{% block title %}Examen Dossier - {{ student.prenom }} {{ student.nom }}{% endblock %}

{% block stylesheets %}
<style>
    .kyc-doc-preview {
        max-width: 100%;
        max-height: 400px;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    .status-timeline {
        border-left: 3px solid #e9ecef;
        padding-left: 20px;
        margin-left: 10px;
    }
    .detail-group { margin-bottom: 25px; }
    .detail-label { font-weight: 600; color: #6c757d; font-size: 0.85rem; text-transform: uppercase; }
    .detail-value { font-size: 1.1rem; color: #212529; }
</style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="kyc-list.php">Liste KYC</a></li>
            <li class="breadcrumb-item active">Examen Dossier</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Main Data -->
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Détails de l'étudiant</h5>
                    <span class="badge bg-info">SOUS RÉVISION</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Prénom & Nom</div>
                            <div class="detail-value">{{ student.prenom }} {{ student.nom }}</div>
                        </div>
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Sexe</div>
                            <div class="detail-value">{{ student.sexe }}</div>
                        </div>
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Email</div>
                            <div class="detail-value">{{ student.email }}</div>
                        </div>
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Téléphone</div>
                            <div class="detail-value">{{ student.telephone }}</div>
                        </div>
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Date de naissance</div>
                            <div class="detail-value">{{ student.dateNaissance }} ({{ student.age }} ans)</div>
                        </div>
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Identité / Passeport</div>
                            <div class="detail-value">{{ student.numeroIdentite }}</div>
                        </div>
                    </div>

                    <hr>

                    <h6 class="text-primary mb-3">Parcours Académique</h6>
                    <div class="row">
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Établissement</div>
                            <div class="detail-value">{{ student.etablissement }}</div>
                        </div>
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Statut</div>
                            <div class="detail-value">{{ student.statut }}</div>
                        </div>
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Niveau d'études</div>
                            <div class="detail-value">{{ student.niveauEtudes }}</div>
                        </div>
                        <div class="col-md-6 detail-group">
                            <div class="detail-label">Domaine d'études</div>
                            <div class="detail-value">{{ student.domaineEtudes }}</div>
                        </div>
                    </div>

                    <hr>

                    <h6 class="text-primary mb-3">Documents Justificatifs</h6>
                    <div class="row g-4">
                        <div class="col-md-6 text-center">
                            <div class="detail-label mb-2">Pièce d'Identité</div>
                            {% if student.identitePath %}
                                <a href="{{ asset(student.identitePath) }}" target="_blank">
                                    <img src="{{ asset(student.identitePath) }}" class="kyc-doc-preview mb-2" onerror="this.src='{{ asset('assets/img/placeholder.png') }}'">
                                </a>
                                <div><a href="{{ asset(student.identitePath) }}" download class="btn btn-sm btn-outline-primary">Télécharger</a></div>
                            {% else %}
                                <div class="alert alert-warning py-2 small">Non fournie</div>
                            {% endif %}
                        </div>
                        <div class="col-md-6 text-center">
                            <div class="detail-label mb-2">Curriculum Vitae (CV)</div>
                            {% if student.cvPath %}
                                <div class="mb-3">
                                    <i class="fas fa-file-pdf fa-4x text-danger"></i>
                                </div>
                                <div>
                                    <a href="{{ asset(student.cvPath) }}" target="_blank" class="btn btn-sm btn-outline-primary me-2">Voir</a>
                                    <a href="{{ asset(student.cvPath) }}" download class="btn btn-sm btn-outline-primary">Télécharger</a>
                                </div>
                            {% else %}
                                <div class="alert alert-warning py-2 small">Non fourni</div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Decisions Sidebar -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-primary mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Prendre une décision</h5>
                </div>
                <div class="card-body">
                    <form action="kyc-detail.php?id={{ student.id }}" method="POST">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        
                        <div class="mb-3">
                            <label for="kyc_notes" class="form-label fw-bold">Notes / Commentaire</label>
                            <textarea class="form-control" id="kyc_notes" name="kyc_notes" rows="4" 
                                      placeholder="Ex: 'Photo d'identité floue', 'Veuillez préciser votre établissement'..."></textarea>
                            <div class="form-text">Obligatoire pour les clarifications ou rejets.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" name="action" value="approve" class="btn btn-success btn-lg">
                                <i class="fas fa-check-circle"></i> Approuver
                            </button>
                            <button type="submit" name="action" value="clarify" class="btn btn-warning">
                                <i class="fas fa-question-circle"></i> Demander Clarification
                            </button>
                            <button type="submit" name="action" value="reject" class="btn btn-danger">
                                <i class="fas fa-times-circle"></i> Rejeter le dossier
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Historique KYC</h6>
                </div>
                <div class="card-body">
                    <div class="status-timeline">
                        <div class="mb-3">
                            <div class="fw-bold small">Dernière mise à jour</div>
                            <div class="text-muted small">{{ student.kycUpdatedAt ? student.kycUpdatedAt|date('d/m/Y H:i') : 'N/A' }}</div>
                        </div>
                        <div>
                            <div class="fw-bold small">Token de révision actif</div>
                            <div class="text-muted text-break small font-monospace">{{ student.reviewToken ?: 'Aucun' }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
